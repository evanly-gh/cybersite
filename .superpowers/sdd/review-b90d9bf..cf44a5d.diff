-  const upR = plinthW * 0.42;
-  for (let i = 0; i < 4; i++) {
-    const a = (i / 4) * Math.PI * 2 + Math.PI / 4;
-    const x = Math.cos(a) * upR;
-    const z = Math.sin(a) * upR;
-    amberParts.push({
-      geom: new THREE.ConeGeometry(0.55, 2.0, 10),
