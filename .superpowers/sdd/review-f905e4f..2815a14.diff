+    const anchor = new THREE.Object3D();
+    anchor.name = 'seat';
+    anchor.position.set(sx, 0.45, sz);
+    anchor.rotation.y = Math.PI;
+    seats.push(anchor);
+    group.add(anchor);
+  }
+
+  // hanging lantern row under the eave
+  const lanternGeom = new THREE.SphereGeometry(0.18, 8, 6);
