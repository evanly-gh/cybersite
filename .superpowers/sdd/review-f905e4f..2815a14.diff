-// (b) Monument
-// ---------------------------------------------------------------------------------
-
-const MONUMENT_H = 22;
-
-/** Draws a small mono plaque texture ("MEMORIAL" style civic plaque). */
-function makePlaqueTexture(): THREE.CanvasTexture {
