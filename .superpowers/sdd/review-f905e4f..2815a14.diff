-    let bestDist = Infinity;
-    for (let i = 0; i < slots.length; i++) {
-      const dist = slots[i].x * slots[i].x + slots[i].z * slots[i].z;
-      if (dist < bestDist) {
-        bestDist = dist;
-        bestIdx = i;
-      }
