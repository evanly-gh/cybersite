+  // 6 stools + seat anchors facing the counter (into the shop, -Z)
+  const stoolGeom = new THREE.CylinderGeometry(0.22, 0.2, 0.45, 8);
+  for (let i = 0; i < 6; i++) {
+    const sx = -w / 2 + 1.2 + i * ((w - 2.4) / 5);
