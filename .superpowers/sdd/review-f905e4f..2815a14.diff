+import type { GeometryPart } from '../../utils/merge';
+import { makeCanvasTexture } from '../../utils/canvasText';
+import { makeAd } from '../../content/adGenerator';
+import {
+  FLOOR_H,
+  boxPart,
+  mergeOne,
+  addTierFacades,
+  makeWindowTexture,
