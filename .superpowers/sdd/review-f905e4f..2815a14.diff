+    const lx = -w / 2 + 1 + i * ((w - 2) / 4);
+    amberParts.push({ geom: lanternGeom, matrix: new THREE.Matrix4().makeTranslation(lx, h - 0.3, d / 2 + 0.5), mat: 0 });
+  }
